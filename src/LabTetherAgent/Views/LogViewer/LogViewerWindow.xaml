<Window
    x:Class="LabTetherAgent.Views.LogViewer.LogViewerWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="LabTether Agent Logs"
    Width="700" Height="500">

    <Grid Padding="16" RowSpacing="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Filter bar -->
        <Grid Grid.Row="0" ColumnSpacing="8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <TextBox Grid.Column="0" PlaceholderText="Search logs..."
                     Text="{x:Bind ViewModel.FilterText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
            <ComboBox Grid.Column="1" SelectedItem="{x:Bind ViewModel.SelectedLevel, Mode=TwoWay}"
                      ItemsSource="{x:Bind ViewModel.LevelOptions}" Width="100" />
            <Button Grid.Column="2" Content="Export" Command="{x:Bind ViewModel.ExportCommand}" />
            <Button Grid.Column="3" Content="Clear" Command="{x:Bind ViewModel.ClearCommand}" />
        </Grid>

        <!-- Log list -->
        <ListView Grid.Row="1" ItemsSource="{x:Bind ViewModel.FilteredLines, Mode=OneWay}"
                  SelectionMode="Extended">
            <ListView.ItemTemplate>
                <DataTemplate>
                    <Grid ColumnSpacing="8" Padding="4,2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="140" />
                            <ColumnDefinition Width="60" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="{Binding Timestamp}"
                                   FontFamily="Cascadia Mono,Consolas" FontSize="11"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                        <Border Grid.Column="1" CornerRadius="3" Padding="4,1"
                                HorizontalAlignment="Left">
                            <TextBlock Text="{Binding Level}" FontSize="10" FontWeight="SemiBold" />
                        </Border>
                        <TextBlock Grid.Column="2" Text="{Binding Message}"
                                   FontFamily="Cascadia Mono,Consolas" FontSize="11"
                                   TextTrimming="CharacterEllipsis" />
                    </Grid>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>

        <!-- Status bar -->
        <Grid Grid.Row="2">
            <TextBlock FontSize="11" Foreground="{ThemeResource TextFillColorSecondaryBrush}">
                <Run Text="{x:Bind ViewModel.FilteredCount, Mode=OneWay}" />
                <Run Text=" / " />
                <Run Text="{x:Bind ViewModel.TotalCount, Mode=OneWay}" />
                <Run Text=" lines" />
            </TextBlock>
            <CheckBox Content="Auto-scroll" HorizontalAlignment="Right"
                      IsChecked="{x:Bind ViewModel.AutoScroll, Mode=TwoWay}" />
        </Grid>
    </Grid>
</Window>
