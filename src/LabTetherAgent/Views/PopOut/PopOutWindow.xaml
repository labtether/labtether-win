<Window
    x:Class="LabTetherAgent.Views.PopOut.PopOutWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:components="using:LabTetherAgent.Components"
    Title="LabTether Metrics"
    Width="300" Height="200">

    <Grid Padding="16" RowSpacing="8">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Status -->
        <components:StatusIndicator Grid.Row="0"
                                    IsConnected="{x:Bind ViewModel.IsConnected, Mode=OneWay}"
                                    StatusText="{x:Bind ViewModel.ConnectionState, Mode=OneWay}" />

        <!-- Metrics -->
        <components:MetricsCard Grid.Row="1"
                                 CpuPercent="{x:Bind ViewModel.CpuPercent, Mode=OneWay}"
                                 MemoryText="{x:Bind ViewModel.MemoryText, Mode=OneWay}"
                                 DiskPercent="{x:Bind ViewModel.DiskPercent, Mode=OneWay}" />

        <!-- Hub info -->
        <StackPanel Grid.Row="2">
            <TextBlock Text="{x:Bind ViewModel.HubUrl, Mode=OneWay}" FontSize="11"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
            <TextBlock Text="{x:Bind ViewModel.Uptime, Mode=OneWay}" FontSize="10"
                       Foreground="{ThemeResource TextFillColorTertiaryBrush}" />
        </StackPanel>
    </Grid>
</Window>
