<ContentDialog
    x:Class="LabTetherAgent.Views.About.AboutDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="About LabTether Agent"
    PrimaryButtonText="Export Diagnostics"
    CloseButtonText="Close"
    DefaultButton="Close">

    <StackPanel Spacing="12" MinWidth="360">
        <!-- App identity -->
        <Grid ColumnSpacing="12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <Border Grid.Column="0" Width="48" Height="48" CornerRadius="8"
                    Background="{ThemeResource AccentFillColorDefaultBrush}">
                <TextBlock Text="LT" FontSize="18" FontWeight="Bold"
                           HorizontalAlignment="Center" VerticalAlignment="Center"
                           Foreground="{ThemeResource TextOnAccentFillColorPrimaryBrush}" />
            </Border>
            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                <TextBlock Text="LabTether Agent" FontSize="16" FontWeight="SemiBold" />
                <TextBlock x:Name="VersionText" FontSize="12"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
            </StackPanel>
        </Grid>

        <MenuFlyoutSeparator />

        <!-- Details -->
        <Grid RowSpacing="6">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="120" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition />
                <RowDefinition />
                <RowDefinition />
                <RowDefinition />
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Grid.Column="0" Text="App Version"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}" FontSize="12" />
            <TextBlock Grid.Row="0" Grid.Column="1" x:Name="AppVersionText" FontSize="12" />

            <TextBlock Grid.Row="1" Grid.Column="0" Text="Agent Version"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}" FontSize="12" />
            <TextBlock Grid.Row="1" Grid.Column="1" x:Name="AgentVersionText" FontSize="12" />

            <TextBlock Grid.Row="2" Grid.Column="0" Text="Hub"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}" FontSize="12" />
            <TextBlock Grid.Row="2" Grid.Column="1" x:Name="HubUrlText" FontSize="12"
                       TextTrimming="CharacterEllipsis" />

            <TextBlock Grid.Row="3" Grid.Column="0" Text="Fingerprint"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}" FontSize="12" />
            <TextBlock Grid.Row="3" Grid.Column="1" x:Name="FingerprintText" FontSize="12"
                       FontFamily="Cascadia Mono,Consolas" IsTextSelectionEnabled="True" />
        </Grid>

        <MenuFlyoutSeparator />

        <!-- Links -->
        <StackPanel Orientation="Horizontal" Spacing="16">
            <HyperlinkButton Content="Website" NavigateUri="https://labtether.com" />
            <HyperlinkButton Content="Documentation" NavigateUri="https://labtether.com/docs" />
        </StackPanel>
    </StackPanel>
</ContentDialog>
