<Page
    x:Class="LabTetherAgent.Views.Onboarding.TokenPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <StackPanel Spacing="16" VerticalAlignment="Center" Padding="0,0,0,48">
        <TextBlock Text="Step 2: Authentication" FontSize="18" FontWeight="SemiBold" />
        <TextBlock Text="Choose how to authenticate with your hub."
                   Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" />

        <!-- Token type selector -->
        <RadioButtons Header="Token Type">
            <RadioButton Content="Enrollment Token" IsChecked="{x:Bind ViewModel.UseEnrollmentToken, Mode=TwoWay}" />
            <RadioButton Content="API Token" />
        </RadioButtons>

        <PasswordBox Header="Token"
                     PlaceholderText="Paste your token from the hub console"
                     Password="{x:Bind ViewModel.Token, Mode=TwoWay}" />
    </StackPanel>
</Page>
