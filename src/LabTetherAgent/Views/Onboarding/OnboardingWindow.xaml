<Window
    x:Class="LabTetherAgent.Views.Onboarding.OnboardingWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="LabTether Agent Setup"
    Width="560" Height="460">

    <Grid Padding="32">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Spacing="4" Margin="0,0,0,24">
            <TextBlock Text="Set Up LabTether Agent" FontSize="24" FontWeight="SemiBold" />
            <TextBlock Text="Connect this machine to your LabTether hub."
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
        </StackPanel>

        <!-- Step indicator -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" Spacing="8" Margin="0,0,0,24"
                    HorizontalAlignment="Center">
            <Ellipse Width="8" Height="8"
                     Fill="{x:Bind StepIndicatorBrush(1, ViewModel.CurrentStep), Mode=OneWay}" />
            <Ellipse Width="8" Height="8"
                     Fill="{x:Bind StepIndicatorBrush(2, ViewModel.CurrentStep), Mode=OneWay}" />
            <Ellipse Width="8" Height="8"
                     Fill="{x:Bind StepIndicatorBrush(3, ViewModel.CurrentStep), Mode=OneWay}" />
        </StackPanel>

        <!-- Step content (Frame for page navigation) -->
        <Frame Grid.Row="2" x:Name="StepFrame" />

        <!-- Navigation buttons -->
        <Grid Grid.Row="3" Margin="0,24,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <Button Grid.Column="1" Content="Back" Margin="0,0,8,0"
                    Command="{x:Bind ViewModel.BackCommand}"
                    IsEnabled="{x:Bind ViewModel.CanGoBack, Mode=OneWay}" />
            <Button Grid.Column="2" Content="Next" Style="{ThemeResource AccentButtonStyle}"
                    Command="{x:Bind ViewModel.NextCommand}"
                    IsEnabled="{x:Bind ViewModel.CanGoNext, Mode=OneWay}"
                    Visibility="{x:Bind IsNotLastStep(ViewModel.CurrentStep), Mode=OneWay}" />
            <Button Grid.Column="2" Content="Finish &amp; Start Agent" Style="{ThemeResource AccentButtonStyle}"
                    Command="{x:Bind ViewModel.FinishCommand}"
                    Visibility="{x:Bind IsLastStep(ViewModel.CurrentStep), Mode=OneWay}" />
        </Grid>
    </Grid>
</Window>
