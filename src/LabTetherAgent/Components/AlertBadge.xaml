<UserControl
    x:Class="LabTetherAgent.Components.AlertBadge"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid Padding="8,4" ColumnSpacing="8">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>
        <Border Grid.Column="0" x:Name="SeverityBadge" CornerRadius="3" Padding="6,2"
                VerticalAlignment="Center">
            <TextBlock x:Name="SeverityText" FontSize="10" FontWeight="SemiBold" />
        </Border>
        <StackPanel Grid.Column="1" VerticalAlignment="Center">
            <TextBlock x:Name="NameText" FontSize="12" FontWeight="SemiBold" />
            <TextBlock x:Name="MessageText" FontSize="10"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                       TextTrimming="CharacterEllipsis" />
        </StackPanel>
    </Grid>
</UserControl>
